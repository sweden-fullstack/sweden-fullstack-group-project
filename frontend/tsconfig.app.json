{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"types": ["vite/client"],

		/* Bundler mode */
		"jsx": "react-jsx",

		/* imports with @ */
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src"]
}
