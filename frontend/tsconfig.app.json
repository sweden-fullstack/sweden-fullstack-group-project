{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"types": ["vite/client"],

		/* Bundler mode */
		"jsx": "react-jsx",

		"rootDir": "..",
		"baseUrl": ".",
		/* imports with @ */
		"paths": {
			"@/*": ["./src/*"],
			"@/shared/*": ["../shared/*"]
		}
	},
	"include": ["src", "../shared"]
}
